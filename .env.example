# Supabase — client-safe values only. NEVER put the service role key here.
# Anon key is safe in the browser because Row Level Security guards every table.
VITE_SUPABASE_URL=https://your-project-ref.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# --- Server-only secrets (Supabase Edge Function env, NOT in this file / not in the client) ---
# SUPABASE_SERVICE_ROLE_KEY=
# CF_ACCOUNT_ID=
# CF_STREAM_API_TOKEN=
# ELEVENLABS_API_KEY=
# ELEVENLABS_VOICE_ID=
# ANTHROPIC_API_KEY=
